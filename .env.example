# Copy to .env and adjust. Loaded optionally by apps/tools that use python-dotenv (optional dependency).

# Root directory for batch outputs (videos, CSVs, figures)
FIGHTSAFE_OUTPUT_DIR=./outputs

# Default config paths (optional overrides)
# FIGHTSAFE_CONFIG=./configs/default.yaml
# FIGHTSAFE_RISK_RULES=./configs/risk_rules.yaml

# Logging
# FIGHTSAFE_LOG_LEVEL=INFO
