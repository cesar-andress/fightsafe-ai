# Backend API (HTTP). WebSocket URL is derived as ws(s)://host/ws/events unless NEXT_PUBLIC_WS_URL is set.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: full WebSocket URL (overrides derivation from NEXT_PUBLIC_API_URL)
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws/events

# Optional: same video file URL/path as served statically or opened in browser (HTML5 video)
# NEXT_PUBLIC_VIDEO_URL=http://127.0.0.1:9000/clips/sample.mp4
